includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - phpstan-baseline.neon

parameters:
    phpVersion: 80200
    level: 8
    paths:
        - packages/core/src
        - packages/http/src
        - packages/routing/src
    excludePaths:
        - packages/*/vendor
        - packages/*/tests
    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: false
