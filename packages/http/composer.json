{
    "name": "nextphp/http",
    "description": "Nextphp Framework — PSR-7/PSR-15 HTTP Layer",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nextphp/routing": "*@dev",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "provide": {
        "psr/http-message-implementation": "^2.0",
        "psr/http-factory-implementation": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Http\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type": "path", "url": "../routing"}
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-clover=coverage.xml",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
