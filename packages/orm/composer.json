{
    "name": "nextphp/orm",
    "description": "Nextphp Framework — Active Record ORM with QueryBuilder and Migrations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nextphp/core": "*@dev",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Orm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Orm\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-clover=coverage.xml",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {"type": "path", "url": "../core"}
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
