{
    "name": "nextphp/migrations",
    "description": "Nextphp Framework — Migrations and schema builder",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nextphp/orm": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Migrations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Migrations\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type":"path","url":"../orm"}
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --no-progress"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
