{
    "name": "nextphp/graphql",
    "description": "Nextphp Framework — lightweight GraphQL component",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nextphp/http": "*@dev",
        "nextphp/routing": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\GraphQL\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type": "path", "url": "../http"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../core"}
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
