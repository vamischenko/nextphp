{
    "name": "nextphp/core",
    "description": "Nextphp Framework — IoC Container with Autowiring and Service Providers",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "provide": {
        "psr/container-implementation": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-clover=coverage.xml",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    }
}
