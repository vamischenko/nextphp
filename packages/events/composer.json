{
    "name": "nextphp/events",
    "description": "Nextphp Framework — PSR-14 Events component",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/event-dispatcher": "^1.0",
        "nextphp/queue": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Events\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Events\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type": "path", "url": "../queue"}
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-clover=coverage.xml",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
