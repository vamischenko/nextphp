{
    "name": "nextphp/debugbar",
    "description": "Nextphp Framework — Debug toolbar (profiler panel) component",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "psr/http-factory": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Nextphp\\Debugbar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nextphp\\Debugbar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
