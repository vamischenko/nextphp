{
    "name": "nextphp/nextphp",
    "description": "Nextphp Framework — modern PHP framework monorepo",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Nextphp Team",
            "email": "team@nextphp.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/simple-cache": "^3.0"
    },
    "suggest": {
        "ext-redis": "Required for nextphp/cache RedisCache driver"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "league/flysystem": "^3.33",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "psalm/plugin-phpunit": "^0.19",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/simple-cache": "^3.0",
        "roave/security-advisories": "dev-latest",
        "symplify/monorepo-builder": "^12.5",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {}
    },
    "autoload-dev": {
        "psr-4": {}
    },
    "replace": {
        "nextphp/core": "self.version",
        "nextphp/http": "self.version",
        "nextphp/routing": "self.version",
        "nextphp/orm": "self.version",
        "nextphp/migrations": "self.version",
        "nextphp/octane": "self.version",
        "nextphp/websocket": "self.version",
        "nextphp/graphql": "self.version",
        "nextphp/view": "self.version",
        "nextphp/console": "self.version",
        "nextphp/cache": "self.version",
        "nextphp/queue": "self.version",
        "nextphp/auth": "self.version",
        "nextphp/validation": "self.version",
        "nextphp/events": "self.version",
        "nextphp/filesystem": "self.version",
        "nextphp/mail": "self.version",
        "nextphp/testing": "self.version"
    },
    "repositories": [
        {"type": "path", "url": "packages/core"},
        {"type": "path", "url": "packages/http"},
        {"type": "path", "url": "packages/routing"},
        {"type": "path", "url": "packages/orm"},
        {"type": "path", "url": "packages/migrations"},
        {"type": "path", "url": "packages/octane"},
        {"type": "path", "url": "packages/websocket"},
        {"type": "path", "url": "packages/graphql"},
        {"type": "path", "url": "packages/view"},
        {"type": "path", "url": "packages/console"},
        {"type": "path", "url": "packages/cache"},
        {"type": "path", "url": "packages/queue"},
        {"type": "path", "url": "packages/auth"},
        {"type": "path", "url": "packages/validation"},
        {"type": "path", "url": "packages/events"},
        {"type": "path", "url": "packages/filesystem"},
        {"type": "path", "url": "packages/mail"},
        {"type": "path", "url": "packages/testing"}
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:core": "cd packages/core && ../../vendor/bin/phpunit",
        "test:http": "cd packages/http && ../../vendor/bin/phpunit",
        "test:routing": "cd packages/routing && ../../vendor/bin/phpunit",
        "test:migrations": "cd packages/migrations && php8.3 ./vendor/bin/phpunit",
        "test:octane": "cd packages/octane && php8.3 ./vendor/bin/phpunit",
        "test:websocket": "cd packages/websocket && php8.3 ./vendor/bin/phpunit",
        "test:graphql": "cd packages/graphql && php8.3 ./vendor/bin/phpunit",
        "test:cache": "cd packages/cache && php ./vendor/bin/phpunit",
        "test:events": "cd packages/events && php ./vendor/bin/phpunit",
        "test:validation": "cd packages/validation && php ./vendor/bin/phpunit",
        "test:queue": "cd packages/queue && php ./vendor/bin/phpunit",
        "test:view": "cd packages/view && php ./vendor/bin/phpunit",
        "test:console": "cd packages/console && php ./vendor/bin/phpunit",
        "test:auth": "cd packages/auth && php ./vendor/bin/phpunit",
        "test:filesystem": "cd packages/filesystem && php ./vendor/bin/phpunit",
        "test:mail": "cd packages/mail && php ./vendor/bin/phpunit",
        "test:testing": "cd packages/testing && php ./vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html=coverage",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "psalm": "vendor/bin/psalm",
        "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "qa": [
            "@cs:check",
            "@analyse",
            "@psalm",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symplify/monorepo-builder": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
