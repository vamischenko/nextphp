        "nextphp/http": "*@dev",
        "nextphp/routing": "*@dev",
        "nextphp/view": "*@dev",
        "nextphp/console": "*@dev",
        "nextphp/validation": "*@dev",
        "nextphp/auth": "*@dev"
    },
    "repositories": [
        {"type": "path", "url": "../../packages/core"},
        {"type": "path", "url": "../../packages/http"},
